# このファイルを .env.local にコピーして使う
# ⚠️ VITE_ で始まる変数だけがブラウザに露出します

# ===== モード切り替えスイッチ =====
# false = デモ版（ローカル保存・固定データ・お金がかからない）
# true  = 発表版（下のキーを使う）
VITE_USE_API=false        # Claude API（画像判定）を使うか
VITE_USE_SUPABASE=false   # Supabase（クラウド保存）を使うか

# ===== Claude API（VITE_USE_API=true のとき必要）=====
VITE_CLAUDE_API_KEY=

# ===== Supabase（VITE_USE_SUPABASE=true のとき必要）=====
VITE_SUPABASE_URL=https://bdrmqzwjbhcrtbdezdad.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_DckYEDlHpY0-3w2f--mjIA_BM93GCQE
