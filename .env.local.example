# このファイルを .env.local にコピーして使う
# ⚠️ VITE_ で始まる変数だけがブラウザに露出します

# ===== モード切り替えスイッチ =====
# false = デモ版（ローカル保存・固定データ・お金がかからない）
# true  = 発表版（下のキーを使う）
VITE_USE_API=false        # Claude API（画像判定）を使うか
VITE_USE_FIREBASE=false   # Firebase（クラウド保存）を使うか

# ===== Claude API（VITE_USE_API=true のとき必要）=====
VITE_CLAUDE_API_KEY=

# ===== Firebase（VITE_USE_FIREBASE=true のとき必要）=====
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_SENDER_ID=
VITE_FB_APP_ID=
