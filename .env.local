# このファイルを .env.local にコピーして使う
# ⚠️ VITE_ で始まる変数だけがブラウザに露出します

# ===== モード切り替えスイッチ =====
# false = デモ版（ローカル保存・固定データ・お金がかからない）
# true  = 本番版（下のキーを使う）
VITE_USE_API=false        # AIを使うか（false=固定データ・モック・無料）
VITE_USE_SUPABASE=false   # Supabase（クラウド保存）を使うか

# ===== AI プロバイダ =====
# VITE_USE_API=true のときのみ有効。未指定なら "claude"。
# "claude" → Claude API を使う（クレジット購入が必要）
# "gemini" → Gemini API を使う（無料枠あり）
VITE_AI_PROVIDER=gemini

# ===== 検証用スイッチ =====
# true にするとタイマーが約10秒に短縮される（ペナルティ時間の動作確認用）
VITE_TIMER_DEBUG=false

# ===== Claude API（VITE_AI_PROVIDER=claude のとき必要）=====
VITE_CLAUDE_API_KEY=

# ===== Gemini API（VITE_AI_PROVIDER=gemini のとき必要）=====
# Google AI Studio ( https://aistudio.google.com/app/apikey ) で無料取得
VITE_GEMINI_API_KEY=

# ===== Supabase（VITE_USE_SUPABASE=true のとき必要）=====
# メール通知（send-penalty-email Edge Function）もSupabaseクライアントを使う
VITE_SUPABASE_URL=https://apampoutybrmzuthrtqe.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_brEXAlpm5yLnobYiQx1spA_2HUZR2MZ
